{% extends 'base.html.twig' %}

{% block title %}Reporter un rendez-vous{% endblock %}

{% block body %}
<div class="min-h-screen bg-gray-50">
    <div class="pt-16 md:pt-20"></div>

    <div class="px-4 py-6 sm:px-6 lg:px-8 max-w-5xl mx-auto">
        <!-- Header -->
        <div class="mb-6">
            <nav class="mb-4" aria-label="Breadcrumb">
                <ol class="flex items-center space-x-2 text-sm">
                    <li><a href="{{ path('app_profile') }}" class="text-pink-600 hover:text-pink-700 font-medium">Mon profil</a></li>
                    <svg class="w-4 h-4 text-gray-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/></svg>
                    <li class="text-gray-900 font-medium">Reporter un rendez-vous</li>
                </ol>
            </nav>
            <h1 class="text-2xl font-bold text-gray-900">📅 Reporter un rendez-vous</h1>
            <p class="text-sm text-gray-600 mt-1">Modifiez la date et/ou le créneau horaire de votre rendez-vous</p>
        </div>

        <!-- Flash Messages -->
        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="mb-6 p-4 text-sm rounded-lg {% if type == 'success' %}text-green-800 bg-green-50 border border-green-200{% elseif type == 'warning' %}text-yellow-800 bg-yellow-50 border border-yellow-200{% else %}text-red-800 bg-red-50 border border-red-200{% endif %}">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            <!-- Informations du rendez-vous actuel -->
            <div class="lg:col-span-1">
                <div class="bg-white rounded-lg shadow-sm border border-gray-200">
                    <div class="px-6 py-4 border-b border-gray-200">
                        <h2 class="text-lg font-semibold text-gray-900">Rendez-vous actuel</h2>
                    </div>
                    <div class="px-6 py-4 space-y-4">
                        <div class="flex items-start">
                            <div class="w-10 h-10 bg-purple-100 rounded-full flex items-center justify-center mr-3 flex-shrink-0">
                                <svg class="w-5 h-5 text-purple-600" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M6 6V5a3 3 0 013-3h2a3 3 0 013 3v1h2a2 2 0 012 2v6a2 2 0 01-2 2H4a2 2 0 01-2-2V8a2 2 0 012-2h2z" clip-rule="evenodd"/>
                                </svg>
                            </div>
                            <div>
                                <p class="text-xs font-medium text-gray-500">Prestation</p>
                                <p class="text-sm text-gray-900 font-medium">{{ rendezvous.prestation.title }}</p>
                            </div>
                        </div>

                        <div class="flex items-start">
                            <div class="w-10 h-10 bg-green-100 rounded-full flex items-center justify-center mr-3 flex-shrink-0">
                                <svg class="w-5 h-5 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"/>
                                </svg>
                            </div>
                            <div>
                                <p class="text-xs font-medium text-gray-500">Date actuelle</p>
                                <p class="text-sm text-gray-900 font-medium">{{ rendezvous.day|date('d/m/Y') }}</p>
                            </div>
                        </div>

                        <div class="flex items-start">
                            <div class="w-10 h-10 bg-orange-100 rounded-full flex items-center justify-center mr-3 flex-shrink-0">
                                <svg class="w-5 h-5 text-orange-600" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/>
                                </svg>
                            </div>
                            <div>
                                <p class="text-xs font-medium text-gray-500">Créneau actuel</p>
                                <p class="text-sm text-gray-900 font-medium">{{ rendezvous.creneau.startTime|date('H:i') }} - {{ rendezvous.creneau.endTime|date('H:i') }}</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Info notification -->
                <div class="mt-4 bg-blue-50 rounded-lg p-4 border border-blue-200">
                    <div class="flex items-start">
                        <svg class="w-5 h-5 text-blue-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
                        </svg>
                        <p class="text-sm text-blue-700 ml-3">Vous recevrez un email de confirmation après la modification.</p>
                    </div>
                </div>
            </div>

            <!-- Formulaire de modification -->
            <div class="lg:col-span-2">
                <div class="bg-white rounded-lg shadow-sm border border-gray-200">
                    <div class="px-6 py-4 border-b border-gray-200">
                        <h2 class="text-lg font-semibold text-gray-900">Nouvelle planification</h2>
                        <p class="text-sm text-gray-500 mt-1">Sélectionnez une nouvelle date et un nouveau créneau</p>
                    </div>
                    <div class="px-6 py-6">
                        {{ form_start(form, {'attr': {'class': 'space-y-6'}}) }}

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <!-- Nouvelle date -->
                            <div class="space-y-2">
                                {{ form_label(form.day, 'Nouvelle date', {'label_attr': {'class': 'block text-sm font-medium text-gray-700'}}) }}
                                <div class="relative">
                                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                        <svg class="h-5 w-5 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                                            <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"/>
                                        </svg>
                                    </div>
                                    <input type="text" name="{{ field_name(form.day) }}" value="{{ field_value(form.day) }}"
                                           placeholder="Sélectionnez une nouvelle date"
                                           class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-pink-500 focus:border-pink-500 block w-full pl-10 p-3"
                                           id="datepicker" readonly>
                                </div>
                                <p class="text-xs text-gray-500">Jours ouvrables : mardi à samedi</p>

                                <div id="date-preview" class="hidden bg-green-50 rounded-lg p-3 border border-green-200">
                                    <p class="text-sm text-green-800">
                                        <span class="font-medium">Date sélectionnée :</span>
                                        <span id="selected-date-display"></span>
                                    </p>
                                </div>
                            </div>

                            <!-- Nouveau créneau -->
                            <div class="space-y-2">
                                {{ form_label(form.creneau, 'Nouveau créneau', {'label_attr': {'class': 'block text-sm font-medium text-gray-700'}}) }}
                                <div id="creneaux-container">
                                    {{ form_widget(form.creneau, {'attr': {'class': 'bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-pink-500 focus:border-pink-500 block w-full p-3'}}) }}
                                </div>
                                <p class="text-xs text-gray-500">Sélectionnez d'abord une date</p>

                                <div id="availability-message" class="hidden">
                                    <div class="bg-yellow-50 rounded-lg p-3 border border-yellow-200">
                                        <p class="text-sm text-yellow-800 font-medium">Chargement des créneaux...</p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Actions -->
                        <div class="flex items-center justify-between pt-6 border-t border-gray-200">
                            <a href="{{ path('app_profile') }}" class="inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-lg text-gray-700 bg-white hover:bg-gray-50 transition-colors">
                                <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd"/>
                                </svg>
                                Retour au profil
                            </a>
                            <button type="submit" id="submit-btn" class="inline-flex items-center px-6 py-2 bg-pink-600 hover:bg-pink-700 text-white font-medium rounded-lg text-sm transition-colors">
                                <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                                </svg>
                                Reporter le rendez-vous
                            </button>
                        </div>

                        {{ form_widget(form._token) }}
                        {{ form_end(form, {'render_rest': false}) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/fr.js"></script>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const slotsDropdown = document.getElementById('rendezvous_modify_creneau');
    const datePreview = document.getElementById('date-preview');
    const selectedDateDisplay = document.getElementById('selected-date-display');
    const availabilityMessage = document.getElementById('availability-message');

    flatpickr("#datepicker", {
        enableTime: false,
        dateFormat: "Y-m-d",
        altInput: true,
        altFormat: "l j F Y",
        locale: "fr",
        minDate: "today",
        disable: [
            function(date) { return (date.getDay() === 1); }, // Lundi
            function(date) { return (date.getDay() === 0); }  // Dimanche
        ],
        onChange: function(selectedDates, dateStr) {
            if (selectedDates.length > 0) {
                selectedDateDisplay.textContent = selectedDates[0].toLocaleDateString('fr-FR', {
                    weekday: 'long', year: 'numeric', month: 'long', day: 'numeric'
                });
                datePreview.classList.remove('hidden');
                loadAvailableSlots(dateStr);
            } else {
                datePreview.classList.add('hidden');
                resetSlotsDropdown();
            }
        }
    });

    function loadAvailableSlots(selectedDate) {
        availabilityMessage.classList.remove('hidden');
        availabilityMessage.innerHTML = '<div class="bg-yellow-50 rounded-lg p-3 border border-yellow-200"><p class="text-sm text-yellow-800 font-medium">Chargement des créneaux disponibles...</p></div>';

        const xhr = new XMLHttpRequest();
        xhr.open('POST', '/get-available-slots', true);
        xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
        xhr.onreadystatechange = function() {
            if (xhr.readyState === XMLHttpRequest.DONE) {
                if (xhr.status === 200) {
                    const slots = JSON.parse(xhr.responseText);
                    updateSlotsDropdown(slots);
                    availabilityMessage.innerHTML = slots.length > 0
                        ? `<div class="bg-green-50 rounded-lg p-3 border border-green-200"><p class="text-sm text-green-800 font-medium">${slots.length} créneau${slots.length > 1 ? 'x' : ''} disponible${slots.length > 1 ? 's' : ''}</p></div>`
                        : '<div class="bg-red-50 rounded-lg p-3 border border-red-200"><p class="text-sm text-red-800 font-medium">Aucun créneau disponible pour cette date</p></div>';
                } else {
                    availabilityMessage.innerHTML = '<div class="bg-red-50 rounded-lg p-3 border border-red-200"><p class="text-sm text-red-800 font-medium">Erreur lors du chargement des créneaux</p></div>';
                }
            }
        };
        xhr.send('date=' + selectedDate);
    }

    function updateSlotsDropdown(slots) {
        slotsDropdown.innerHTML = '<option value="">Sélectionnez un créneau</option>';
        slots.forEach(function(slot) {
            const option = document.createElement('option');
            option.value = slot.id;
            option.text = slot.libelle;
            slotsDropdown.appendChild(option);
        });
        slotsDropdown.disabled = slots.length === 0;
    }

    function resetSlotsDropdown() {
        slotsDropdown.innerHTML = "<option value=''>Sélectionnez d'abord une date</option>";
        slotsDropdown.disabled = true;
        availabilityMessage.classList.add('hidden');
    }

    resetSlotsDropdown();

    document.querySelector('form').addEventListener('submit', function(e) {
        const dateVal = document.getElementById('datepicker').value;
        const slotVal = document.getElementById('rendezvous_modify_creneau').value;
        if (!dateVal) {
            e.preventDefault();
            showError('Veuillez sélectionner une nouvelle date.');
        } else if (!slotVal) {
            e.preventDefault();
            showError('Veuillez sélectionner un créneau horaire.');
        }
    });

    function showError(message) {
        const existing = document.getElementById('validation-error');
        if (existing) existing.remove();
        const div = document.createElement('div');
        div.id = 'validation-error';
        div.className = 'mb-4 p-4 text-sm rounded-lg text-red-800 bg-red-50 border border-red-200';
        div.textContent = message;
        document.querySelector('.px-6.py-6').prepend(div);
        div.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
});
</script>

<style>
.flatpickr-day.today { background: #fef3f2; border-color: #ec4899; color: #ec4899; }
.flatpickr-day.selected { background: #ec4899; border-color: #ec4899; }
.flatpickr-day:hover { background: #fdf2f8; }
</style>
{% endblock %}
