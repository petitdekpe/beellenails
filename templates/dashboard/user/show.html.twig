{% extends 'dashboard.html.twig' %}

{% block title %}{{ user.fullName }} - Dashboard{% endblock %}

{% block content %}
<div class="max-w-7xl mx-auto">

    <!-- Header -->
    <div class="mb-6">
        <nav class="flex items-center space-x-2 text-sm mb-3" aria-label="Breadcrumb">
            <a href="{{ path('app_dashboard_user') }}" class="text-gray-500 hover:text-gray-700">Clients</a>
            <svg class="w-4 h-4 text-gray-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/></svg>
            <span class="text-gray-900 font-medium">{{ user.fullName }}</span>
        </nav>
        <div class="flex items-center justify-between">
            <div>
                <h1 class="text-2xl font-bold text-gray-900">{{ user.fullName }}</h1>
                <p class="text-sm text-gray-500 mt-1">
                    Client depuis {{ user.createdAt ? user.createdAt|date('F Y') : 'N/A' }}
                    {% if 'ROLE_ADMIN' in user.roles %}
                        · <span class="text-purple-600 font-medium">👑 Administrateur</span>
                    {% endif %}
                </p>
            </div>
            <div class="flex items-center gap-3">
                <a href="{{ path('app_admin_rdv') }}" class="inline-flex items-center px-4 py-2 bg-pink-600 hover:bg-pink-700 text-white text-sm font-medium rounded-lg transition-colors">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                    </svg>
                    Nouveau RDV
                </a>
                <a href="{{ path('app_user_edit', {'id': user.id}) }}" class="inline-flex items-center px-4 py-2 bg-white border border-gray-300 hover:bg-gray-50 text-gray-700 text-sm font-medium rounded-lg transition-colors">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                    </svg>
                    Modifier
                </a>
            </div>
        </div>
    </div>

    <!-- Statistiques -->
    {% set rdvPris = user.rendezvouses|filter(r => r.status == 'Rendez-vous pris')|length %}
    {% set rdvConfirme = user.rendezvouses|filter(r => r.status == 'Rendez-vous confirmé')|length %}
    {% set rdvAnnule = user.rendezvouses|filter(r => r.status == 'Annulé')|length %}
    {% set rdvTotal = rdvPris + rdvConfirme %}

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
        <div class="bg-white rounded-lg shadow p-4">
            <p class="text-sm text-gray-500">RDV actifs</p>
            <p class="text-3xl font-bold text-blue-600 mt-1">{{ rdvTotal }}</p>
            {% if rdvTotal >= 5 %}
                <p class="text-xs text-orange-500 mt-1">⭐ Client fidèle</p>
            {% endif %}
        </div>
        <div class="bg-white rounded-lg shadow p-4">
            <p class="text-sm text-gray-500">Confirmés</p>
            <p class="text-3xl font-bold text-green-600 mt-1">{{ rdvConfirme }}</p>
        </div>
        <div class="bg-white rounded-lg shadow p-4">
            <p class="text-sm text-gray-500">En attente</p>
            <p class="text-3xl font-bold text-orange-500 mt-1">{{ rdvPris }}</p>
        </div>
        <div class="bg-white rounded-lg shadow p-4">
            <p class="text-sm text-gray-500">Annulés</p>
            <p class="text-3xl font-bold text-red-500 mt-1">{{ rdvAnnule }}</p>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

        <!-- Colonne gauche : infos client -->
        <div class="space-y-6">

            <!-- Informations personnelles -->
            <div class="bg-white rounded-lg shadow">
                <div class="px-6 py-4 border-b border-gray-200">
                    <h2 class="text-base font-semibold text-gray-900">Informations personnelles</h2>
                </div>
                <div class="px-6 py-4 space-y-3">
                    <div class="flex justify-between items-center">
                        <span class="text-sm text-gray-500">Prénom</span>
                        <span class="text-sm font-medium text-gray-900">{{ user.Prenom ?: '—' }}</span>
                    </div>
                    <div class="flex justify-between items-center">
                        <span class="text-sm text-gray-500">Nom</span>
                        <span class="text-sm font-medium text-gray-900">{{ user.Nom ?: '—' }}</span>
                    </div>
                    {% if user.genre %}
                    <div class="flex justify-between items-center">
                        <span class="text-sm text-gray-500">Genre</span>
                        <span class="text-sm font-medium text-gray-900">{{ user.genre }}</span>
                    </div>
                    {% endif %}
                    {% if user.birthday %}
                    <div class="flex justify-between items-center">
                        <span class="text-sm text-gray-500">Anniversaire</span>
                        <span class="text-sm font-medium text-gray-900">🎂 {{ user.birthday|date('d/m/Y') }}</span>
                    </div>
                    {% endif %}
                    <div class="flex justify-between items-center">
                        <span class="text-sm text-gray-500">Inscrit le</span>
                        <span class="text-sm text-gray-900">{{ user.createdAt ? user.createdAt|date('d/m/Y') : '—' }}</span>
                    </div>
                </div>
            </div>

            <!-- Contact -->
            <div class="bg-white rounded-lg shadow">
                <div class="px-6 py-4 border-b border-gray-200">
                    <h2 class="text-base font-semibold text-gray-900">Contact</h2>
                </div>
                <div class="px-6 py-4 space-y-3">
                    <div>
                        <p class="text-xs text-gray-400 mb-0.5">Email</p>
                        <a href="mailto:{{ user.email }}" class="text-sm text-pink-600 hover:text-pink-800 font-medium break-all">{{ user.email }}</a>
                    </div>
                    <div>
                        <p class="text-xs text-gray-400 mb-0.5">Téléphone</p>
                        {% if user.Phone %}
                            <a href="tel:{{ user.Phone }}" class="text-sm text-pink-600 hover:text-pink-800 font-medium">{{ user.Phone }}</a>
                        {% else %}
                            <span class="text-sm text-gray-400 italic">Non renseigné</span>
                        {% endif %}
                    </div>
                </div>
            </div>

            <!-- Paiements -->
            <div class="bg-white rounded-lg shadow">
                <div class="px-6 py-4 border-b border-gray-200">
                    <h2 class="text-base font-semibold text-gray-900">Paiements</h2>
                </div>
                <div class="px-6 py-4">
                    {% if user.payments|length > 0 %}
                        <div class="space-y-3 max-h-64 overflow-y-auto">
                            {% for payment in user.payments %}
                                <div class="flex items-center justify-between p-3 bg-green-50 rounded-lg">
                                    <div>
                                        <p class="text-sm font-medium text-gray-900">
                                            {% if payment.rendezvous is defined and payment.rendezvous %}
                                                {{ payment.rendezvous.prestation.title }}
                                            {% else %}
                                                Paiement
                                            {% endif %}
                                        </p>
                                        <p class="text-xs text-gray-500">{{ payment.createdAt|date('d/m/Y') }}</p>
                                    </div>
                                    <span class="text-sm font-bold text-green-600">
                                        {% if payment.rendezvous is defined and payment.rendezvous %}
                                            {{ payment.rendezvous.totalCost|number_format(0, ',', ' ') }} XOF
                                        {% endif %}
                                    </span>
                                </div>
                            {% endfor %}
                        </div>
                    {% else %}
                        <p class="text-sm text-gray-400 italic text-center py-4">Aucun paiement enregistré</p>
                    {% endif %}
                </div>
            </div>
        </div>

        <!-- Colonne droite : historique RDV -->
        <div class="lg:col-span-2">
            <div class="bg-white rounded-lg shadow">
                <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
                    <h2 class="text-base font-semibold text-gray-900">Historique des rendez-vous</h2>
                    <span class="text-sm text-gray-500">{{ user.rendezvouses|length }} au total</span>
                </div>
                <div class="overflow-hidden">
                    {% if user.rendezvouses|length > 0 %}
                        {% set sortedRdv = user.rendezvouses|sort((a, b) => b.day <=> a.day) %}
                        <table class="min-w-full divide-y divide-gray-200">
                            <thead class="bg-pink-50">
                                <tr>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-pink-600 uppercase tracking-wider">Date</th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-pink-600 uppercase tracking-wider">Prestation</th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-pink-600 uppercase tracking-wider">Statut</th>
                                    <th class="px-6 py-3 text-right text-xs font-medium text-pink-600 uppercase tracking-wider">Actions</th>
                                </tr>
                            </thead>
                            <tbody class="bg-white divide-y divide-gray-100">
                                {% for rdv in sortedRdv %}
                                    {% if rdv.status != 'Congé' %}
                                    <tr class="hover:bg-gray-50 transition-colors">
                                        <td class="px-6 py-3">
                                            <p class="text-sm font-medium text-gray-900">{{ rdv.day|date('d/m/Y') }}</p>
                                            <p class="text-xs text-gray-400">{{ rdv.creneau.startTime|date('H:i') }} – {{ rdv.creneau.endTime|date('H:i') }}</p>
                                        </td>
                                        <td class="px-6 py-3">
                                            <p class="text-sm text-gray-900">{{ rdv.prestation.title }}</p>
                                            {% if rdv.totalCost %}
                                                <p class="text-xs text-gray-400">{{ rdv.totalCost|number_format(0, ',', ' ') }} XOF</p>
                                            {% endif %}
                                        </td>
                                        <td class="px-6 py-3">
                                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                                                {% if rdv.status == 'Rendez-vous pris' %}bg-orange-100 text-orange-700
                                                {% elseif rdv.status == 'Rendez-vous confirmé' %}bg-green-100 text-green-700
                                                {% elseif rdv.status == 'Annulé' %}bg-red-100 text-red-700
                                                {% elseif rdv.status == 'Reporté' %}bg-blue-100 text-blue-700
                                                {% else %}bg-gray-100 text-gray-600{% endif %}">
                                                {{ rdv.status }}
                                            </span>
                                        </td>
                                        <td class="px-6 py-3 text-right">
                                            {% if rdv.status not in ['Annulé'] %}
                                                <a href="{{ path('app_admin_rdv_edit', {'id': rdv.id}) }}"
                                                   class="text-sm text-blue-600 hover:text-blue-800 font-medium">
                                                    Reporter
                                                </a>
                                            {% endif %}
                                        </td>
                                    </tr>
                                    {% endif %}
                                {% endfor %}
                            </tbody>
                        </table>
                    {% else %}
                        <div class="px-6 py-12 text-center">
                            <svg class="mx-auto h-10 w-10 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                            </svg>
                            <p class="mt-3 text-sm text-gray-400">Aucun rendez-vous pour ce client</p>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
