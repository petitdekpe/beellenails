{% extends 'mobile/base.html.twig' %}

{% block title %}Clients - Mobile{% endblock %}
{% block page_title %}Clients{% endblock %}

{% block content %}
<!-- En-tête avec bouton ajout -->
<div class="flex items-center justify-between mb-4">
    <span class="text-sm text-gray-500">
        {% if users|length > 0 %}{{ users.getTotalItemCount }} client(s){% endif %}
    </span>
    <a href="{{ path('app_mobile_client_add') }}"
       class="flex items-center gap-1.5 px-3 py-2 bg-pink-500 text-white text-sm font-semibold rounded-xl hover:bg-pink-600 active:bg-pink-700 transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/>
        </svg>
        Nouveau client
    </a>
</div>

<!-- Recherche -->
<form method="GET" class="mb-4">
    <div class="flex gap-2">
        <div class="flex-1 relative">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
            <input type="text"
                   name="search"
                   value="{{ search }}"
                   placeholder="Nom, email, téléphone..."
                   class="form-control pl-10"
                   id="search-input">
        </div>
        <button type="submit" class="px-4 py-3 bg-pink-500 text-white rounded-xl font-medium flex-shrink-0">
            OK
        </button>
    </div>
</form>

{% if users|length > 0 %}

    {% for user in users %}
        <a href="{{ path('app_mobile_client_show', {'id': user.id}) }}" class="card flex items-center gap-3 active:bg-gray-50 transition-colors">
            <!-- Avatar -->
            <div class="w-12 h-12 bg-pink-100 rounded-full flex items-center justify-center flex-shrink-0">
                <span class="text-base font-bold text-pink-600">
                    {% if user.Prenom and user.Nom %}
                        {{ user.Prenom|slice(0,1)|upper }}{{ user.Nom|slice(0,1)|upper }}
                    {% else %}
                        ?
                    {% endif %}
                </span>
            </div>
            <!-- Infos -->
            <div class="flex-1 min-w-0">
                <p class="font-semibold text-gray-900 truncate">{{ user.fullName }}</p>
                <p class="text-sm text-gray-500 truncate">{{ user.email }}</p>
                {% if user.Phone %}
                    <p class="text-xs text-gray-400">{{ user.Phone }}</p>
                {% endif %}
            </div>
            <!-- RDV count -->
            <div class="flex flex-col items-center flex-shrink-0">
                {% set rdvCount = 0 %}
                {% for rdv in user.rendezvouses %}
                    {% if rdv.status in ['Rendez-vous pris', 'Rendez-vous confirmé'] %}
                        {% set rdvCount = rdvCount + 1 %}
                    {% endif %}
                {% endfor %}
                <span class="text-lg font-bold {{ rdvCount > 0 ? 'text-green-600' : 'text-gray-300' }}">{{ rdvCount }}</span>
                <span class="text-[10px] text-gray-400">RDV</span>
                {% if rdvCount >= 5 %}
                    <span class="text-[10px] text-orange-500">⭐</span>
                {% endif %}
            </div>
            <!-- Chevron -->
            <svg class="w-5 h-5 text-gray-300 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
        </a>
    {% endfor %}

    <!-- Pagination -->
    {% if users.getPageCount > 1 %}
        <div class="flex justify-center gap-3 mt-4 mb-2">
            {% if users.getCurrentPageNumber > 1 %}
                <a href="{{ path('app_mobile_clients', app.request.query.all|merge({'page': users.getCurrentPageNumber - 1})) }}"
                   class="px-4 py-2 bg-white border border-gray-200 rounded-xl text-sm font-medium text-gray-700">
                    Précédent
                </a>
            {% endif %}
            <span class="px-4 py-2 text-sm text-gray-500">
                {{ users.getCurrentPageNumber }} / {{ users.getPageCount }}
            </span>
            {% if users.getCurrentPageNumber < users.getPageCount %}
                <a href="{{ path('app_mobile_clients', app.request.query.all|merge({'page': users.getCurrentPageNumber + 1})) }}"
                   class="px-4 py-2 bg-white border border-gray-200 rounded-xl text-sm font-medium text-gray-700">
                    Suivant
                </a>
            {% endif %}
        </div>
    {% endif %}

{% else %}
    <div class="card text-center py-8">
        <svg class="mx-auto w-12 h-12 text-gray-300 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
        <p class="text-gray-500 font-medium">
            {% if search %}Aucun client trouvé{% else %}Aucun client{% endif %}
        </p>
        {% if search %}
            <a href="{{ path('app_mobile_clients') }}" class="mt-3 inline-block text-pink-500 text-sm">Réinitialiser</a>
        {% endif %}
    </div>
{% endif %}
{% endblock %}

{% block javascripts %}
<script>
let timer;
document.getElementById('search-input')?.addEventListener('input', function(e) {
    clearTimeout(timer);
    timer = setTimeout(() => {
        if (e.target.value.length >= 2 || e.target.value.length === 0) {
            e.target.form.submit();
        }
    }, 500);
});
</script>
{% endblock %}
