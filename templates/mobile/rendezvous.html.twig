{% extends 'mobile/base.html.twig' %}

{% block title %}Rendez-vous - Mobile{% endblock %}
{% block page_title %}Rendez-vous{% endblock %}

{% block content %}

<!-- Filtres -->
<form method="GET" id="filter-form" class="mb-4 space-y-2">

    <!-- Recherche -->
    <div class="flex gap-2">
        <div class="flex-1 relative">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
            <input type="text" name="search" value="{{ search }}"
                   placeholder="Rechercher un client..."
                   class="form-control pl-10" id="search-input">
        </div>
        <button type="submit" class="px-4 py-3 bg-pink-500 text-white rounded-xl font-semibold flex-shrink-0 text-sm">
            OK
        </button>
    </div>

    <!-- Statut -->
    <select name="status" onchange="this.form.submit()" class="form-control">
        <option value="all"                  {{ not status or status == 'all'                  ? 'selected' : '' }}>Tous les statuts</option>
        <option value="Rendez-vous pris"     {{ status == 'Rendez-vous pris'                   ? 'selected' : '' }}>Rendez-vous pris</option>
        <option value="Rendez-vous confirmé" {{ status == 'Rendez-vous confirmé'               ? 'selected' : '' }}>Rendez-vous confirmé</option>
        <option value="Annulé"               {{ status == 'Annulé'                             ? 'selected' : '' }}>Annulé</option>
        <option value="Reporté"              {{ status == 'Reporté'                            ? 'selected' : '' }}>Reporté</option>
        <option value="Paiement en attente"  {{ status == 'Paiement en attente'                ? 'selected' : '' }}>Paiement en attente</option>
        <option value="Échec du paiement"    {{ status == 'Échec du paiement'                  ? 'selected' : '' }}>Échec du paiement</option>
        <option value="Tentative"            {{ status == 'Tentative'                          ? 'selected' : '' }}>Tentative</option>
    </select>

    <!-- Filtre par date (collapsed par défaut) -->
    <div>
        <button type="button" id="toggle-dates"
                class="flex items-center gap-1 text-sm text-gray-500 py-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
            Filtrer par date
            {% if rdv_date_from or rdv_date_to %}
                <span class="ml-1 w-2 h-2 rounded-full bg-pink-500 inline-block"></span>
            {% endif %}
            <svg id="toggle-arrow" class="w-4 h-4 transition-transform {{ rdv_date_from or rdv_date_to ? 'rotate-180' : '' }}" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
        </button>

        <div id="date-filters" class="{{ rdv_date_from or rdv_date_to ? '' : 'hidden' }} space-y-2 mt-2">
            <div class="grid grid-cols-2 gap-2">
                <div>
                    <label class="text-xs text-gray-500 mb-1 block">RDV du</label>
                    <input type="date" name="rdv_date_from" value="{{ rdv_date_from }}" class="form-control text-sm py-2">
                </div>
                <div>
                    <label class="text-xs text-gray-500 mb-1 block">au</label>
                    <input type="date" name="rdv_date_to" value="{{ rdv_date_to }}" class="form-control text-sm py-2">
                </div>
            </div>
            <div class="flex gap-2">
                <button type="submit" class="flex-1 py-2 bg-pink-500 text-white text-sm font-semibold rounded-xl">Filtrer</button>
                <a href="{{ path('app_mobile_rendezvous') }}" class="flex-1 py-2 bg-gray-100 text-gray-700 text-sm font-semibold rounded-xl text-center">Réinitialiser</a>
            </div>
        </div>
    </div>
</form>

{% if rendezvous|length > 0 %}
    <p class="text-xs text-gray-500 mb-3">{{ rendezvous.getTotalItemCount }} rendez-vous</p>

    {% for rdv in rendezvous %}
        {% set isCancelled = rdv.status == 'Annulé' %}
        {% set isConfirmed = rdv.status == 'Rendez-vous confirmé' %}
        {% set statusLower = rdv.status|lower %}
        {% set onlyConfirmAllowed = statusLower in ['paiement en attente', 'échec du paiement'] or statusLower starts with 'tentative échou' %}

        <div class="card">
            <!-- En-tête : client + statut -->
            <div class="flex items-start justify-between gap-2 mb-2">
                <div class="flex items-center gap-2 min-w-0">
                    <div class="w-9 h-9 bg-pink-100 rounded-full flex items-center justify-center flex-shrink-0">
                        <span class="text-xs font-bold text-pink-600">
                            {% if rdv.user %}
                                {{ rdv.user.Prenom|slice(0,1)|upper }}{{ rdv.user.Nom|slice(0,1)|upper }}
                            {% else %}?{% endif %}
                        </span>
                    </div>
                    <div class="min-w-0">
                        <p class="text-sm font-semibold text-gray-900 truncate">
                            {{ rdv.user ? rdv.user.fullName : 'Utilisateur supprimé' }}
                        </p>
                        {% if rdv.user %}
                            <p class="text-xs text-gray-400 truncate">{{ rdv.user.email }}</p>
                        {% endif %}
                    </div>
                </div>
                <div class="flex-shrink-0 text-right">
                    {% set status_colors = {
                        'Rendez-vous pris':     'bg-blue-100 text-blue-800',
                        'Rendez-vous confirmé': 'bg-green-100 text-green-800',
                        'Annulé':               'bg-red-100 text-red-800',
                        'Reporté':              'bg-orange-100 text-orange-800',
                        'Paiement en attente':  'bg-yellow-100 text-yellow-800',
                        'Échec du paiement':    'bg-red-200 text-red-900',
                        'Tentative':            'bg-orange-100 text-orange-800',
                        'Congé':                'bg-purple-100 text-purple-800'
                    } %}
                    {% set status_class = status_colors[rdv.status] ?? 'bg-gray-100 text-gray-800' %}
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium {{ status_class }}">
                        {{ rdv.status }}
                    </span>
                    {% if rdv.paid %}
                        <p class="text-xs text-green-600 mt-0.5">✅ Payé</p>
                    {% endif %}
                </div>
            </div>

            <!-- Détails : date, heure, prestation, prix -->
            <div class="grid grid-cols-2 gap-x-4 gap-y-1 mb-3 text-sm">
                <div class="flex items-center gap-1 text-gray-600">
                    <svg class="w-4 h-4 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                    </svg>
                    {{ rdv.day|date('d/m/Y') }}
                </div>
                <div class="flex items-center gap-1 text-gray-600">
                    <svg class="w-4 h-4 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    {{ rdv.creneau.startTime|date('H:i') }} – {{ rdv.creneau.endTime|date('H:i') }}
                </div>
                <div class="col-span-2 text-gray-700 font-medium truncate">{{ rdv.prestation.Title }}</div>
                <div class="flex items-center gap-2">
                    <span class="font-semibold text-pink-600">
                        {% if rdv.totalCost %}
                            {{ rdv.totalCost|number_format(0, ',', ' ') }} F CFA
                        {% else %}
                            {{ (rdv.prestation.price / 100)|number_format(0, ',', ' ') }} F CFA
                        {% endif %}
                    </span>
                </div>
                {% if rdv.promoCode %}
                    <div>
                        <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs bg-orange-100 text-orange-700">
                            🎟️ {{ rdv.promoCode.code }}
                        </span>
                    </div>
                {% elseif rdv.pendingPromoCode %}
                    <div>
                        <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs bg-yellow-100 text-yellow-700">
                            ⏳ {{ rdv.pendingPromoCode }}
                        </span>
                    </div>
                {% endif %}
                {% if rdv.supplement|length > 0 %}
                    <div class="col-span-2 text-xs text-blue-600">+ {{ rdv.supplement|length }} supplément(s)</div>
                {% endif %}
            </div>

            <!-- Dernière modif -->
            <p class="text-xs text-gray-400 mb-3">Modifié le {{ rdv.updatedAt|date('d/m/Y à H:i') }}</p>

            <!-- Actions -->
            <div class="flex flex-wrap gap-2 pt-2 border-t border-gray-100">

                {% if rdv.imageName %}
                    <button type="button"
                            onclick="openImageModal('{{ vich_uploader_asset(rdv, 'image') }}')"
                            class="flex items-center gap-1.5 px-3 py-2 bg-blue-50 text-blue-600 rounded-xl text-xs font-semibold">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                        </svg>
                        Image
                    </button>
                {% endif %}

                {% if not isCancelled and (not onlyConfirmAllowed or not isConfirmed) %}
                    <a href="{{ path('app_mobile_rdv_edit', {'id': rdv.id}) }}"
                       class="flex items-center gap-1.5 px-3 py-2 bg-orange-50 text-orange-600 rounded-xl text-xs font-semibold">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                        </svg>
                        Reporter
                    </a>
                {% endif %}

                {% if not isConfirmed %}
                    <a href="{{ path('app_admin_rdv_confirm', {'id': rdv.id}) }}"
                       class="flex items-center gap-1.5 px-3 py-2 bg-green-50 text-green-600 rounded-xl text-xs font-semibold">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                        </svg>
                        Confirmer
                    </a>
                {% endif %}

                {% if not isCancelled and not onlyConfirmAllowed %}
                    <a href="{{ path('app_admin_rdv_cancel', {'id': rdv.id}) }}"
                       class="flex items-center gap-1.5 px-3 py-2 bg-red-50 text-red-600 rounded-xl text-xs font-semibold"
                       onclick="return confirm('Annuler ce rendez-vous ?')">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                        </svg>
                        Annuler
                    </a>
                {% endif %}

                {% if rdv.user %}
                    <a href="{{ path('app_mobile_client_show', {'id': rdv.user.id}) }}"
                       class="flex items-center gap-1.5 px-3 py-2 bg-gray-50 text-gray-600 rounded-xl text-xs font-semibold">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                        </svg>
                        Client
                    </a>
                {% endif %}
            </div>
        </div>
    {% endfor %}

    <!-- Pagination -->
    {% if rendezvous.getPageCount > 1 %}
        <div class="flex justify-center gap-3 mt-4 mb-2">
            {% if rendezvous.getCurrentPageNumber > 1 %}
                <a href="{{ path('app_mobile_rendezvous', app.request.query.all|merge({'page': rendezvous.getCurrentPageNumber - 1})) }}"
                   class="px-4 py-2 bg-white border border-gray-200 rounded-xl text-sm font-medium text-gray-700">
                    Précédent
                </a>
            {% endif %}
            <span class="px-4 py-2 text-sm text-gray-500">
                {{ rendezvous.getCurrentPageNumber }} / {{ rendezvous.getPageCount }}
            </span>
            {% if rendezvous.getCurrentPageNumber < rendezvous.getPageCount %}
                <a href="{{ path('app_mobile_rendezvous', app.request.query.all|merge({'page': rendezvous.getCurrentPageNumber + 1})) }}"
                   class="px-4 py-2 bg-white border border-gray-200 rounded-xl text-sm font-medium text-gray-700">
                    Suivant
                </a>
            {% endif %}
        </div>
    {% endif %}

{% else %}
    <div class="card text-center py-8">
        <svg class="mx-auto w-12 h-12 text-gray-300 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
        <p class="text-gray-500 font-medium">Aucun rendez-vous trouvé</p>
        {% if search or (status and status != 'all') or rdv_date_from or rdv_date_to %}
            <a href="{{ path('app_mobile_rendezvous') }}" class="mt-3 inline-block text-pink-500 text-sm font-medium">
                Réinitialiser les filtres
            </a>
        {% endif %}
    </div>
{% endif %}

<!-- Modal image -->
<div id="imageModal" class="hidden fixed inset-0 bg-black bg-opacity-80 z-[100] flex items-center justify-center p-4"
     onclick="closeImageModal()">
    <div class="relative max-w-full max-h-full" onclick="event.stopPropagation()">
        <button onclick="closeImageModal()"
                class="absolute -top-10 right-0 text-white text-3xl font-bold leading-none">&times;</button>
        <img id="modalImage" src="" alt="Image du rendez-vous"
             class="max-w-full max-h-[85vh] rounded-xl shadow-2xl object-contain">
    </div>
</div>

{% endblock %}

{% block javascripts %}
<script>
function openImageModal(url) {
    document.getElementById('modalImage').src = url;
    document.getElementById('imageModal').classList.remove('hidden');
    document.body.style.overflow = 'hidden';
}
function closeImageModal() {
    document.getElementById('imageModal').classList.add('hidden');
    document.body.style.overflow = '';
}
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeImageModal(); });

// Toggle date filters
document.getElementById('toggle-dates').addEventListener('click', function() {
    const panel = document.getElementById('date-filters');
    const arrow = document.getElementById('toggle-arrow');
    panel.classList.toggle('hidden');
    arrow.classList.toggle('rotate-180');
});
</script>
{% endblock %}
