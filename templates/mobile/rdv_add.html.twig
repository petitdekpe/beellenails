{% extends 'mobile/base.html.twig' %}

{% block title %}Nouveau RDV - Mobile{% endblock %}
{% block page_title %}Nouveau RDV{% endblock %}

{% block topbar_left %}
<a href="{{ path('app_mobile_rendezvous') }}" class="w-8 h-8 flex items-center justify-center rounded-full bg-gray-100">
    <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
    </svg>
</a>
{% endblock %}

{% block content %}
<div class="mb-4">
    <p class="text-sm text-gray-500">Créez un rendez-vous pour un client existant</p>
</div>

<!-- Info client inexistant -->
<div class="card !mb-4 bg-blue-50 border border-blue-200">
    <div class="flex items-start gap-2">
        <svg class="w-5 h-5 text-blue-600 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
        </svg>
        <p class="text-sm text-blue-800">
            Nouveau client ? Inscrivez-le d'abord depuis le
            <a href="{{ path('app_dashboard_add_user') }}" class="font-semibold underline">bureau</a>.
        </p>
    </div>
</div>

{{ form_start(form, {'attr': {'id': 'rdv-form', 'class': 'space-y-0', 'novalidate': 'novalidate'}}) }}

<!-- Client -->
<div class="form-group">
    <label class="form-label">Client *</label>
    <div class="relative">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400 pointer-events-none" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"/>
        </svg>
        {{ form_widget(form.user, {'attr': {'class': 'form-control pl-10 js-client-select'}}) }}
    </div>
    {{ form_errors(form.user) }}
</div>

<!-- Prestation -->
<div class="form-group">
    <label class="form-label">Prestation *</label>
    <div class="relative">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400 pointer-events-none" fill="currentColor" viewBox="0 0 20 20">
            <path d="M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM14 15a4 4 0 00-8 0v3h8v-3z"/>
        </svg>
        {{ form_widget(form.prestation, {'attr': {'class': 'form-control pl-10'}}) }}
    </div>
    {{ form_errors(form.prestation) }}
</div>

<!-- Supplément -->
<div class="form-group">
    <label class="form-label">Supplément <span class="text-gray-400 font-normal">(optionnel)</span></label>
    {{ form_widget(form.supplement, {'attr': {'class': 'form-control'}}) }}
    {{ form_errors(form.supplement) }}
</div>

<!-- Date -->
<div class="form-group">
    <label class="form-label" for="datepicker">Date du rendez-vous *</label>
    <div class="relative">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400 pointer-events-none" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"/>
        </svg>
        <input type="text"
               name="{{ field_name(form.day) }}"
               value="{{ field_value(form.day) }}"
               placeholder="Choisir une date"
               class="form-control pl-10"
               id="datepicker"
               readonly>
    </div>
    <p class="text-xs text-gray-400 mt-1">Du mardi au samedi uniquement</p>
</div>

<!-- Créneau -->
<div class="form-group">
    <label class="form-label">Créneau *</label>
    <div id="creneaux-container">
        {{ form_widget(form.creneau, {'attr': {'class': 'form-control', 'disabled': 'disabled', 'id': 'admin_add_rdv_creneau'}}) }}
    </div>
    <div id="availability-message" class="hidden mt-2"></div>
    {{ form_errors(form.creneau) }}
</div>

<!-- Code promo -->
{% if form.pendingPromoCode is defined %}
<div class="form-group">
    <label class="form-label">Code promo <span class="text-gray-400 font-normal">(optionnel)</span></label>
    {{ form_widget(form.pendingPromoCode, {'attr': {'class': 'form-control'}}) }}
</div>
{% endif %}

<!-- Boutons -->
<div class="space-y-3 pt-2">
    <button type="submit" class="btn-primary gap-2">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
        </svg>
        Créer le rendez-vous
    </button>
    <a href="{{ path('app_mobile_rendezvous') }}" class="btn-secondary gap-2">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
        Annuler
    </a>
</div>

{{ form_widget(form._token) }}
{{ form_end(form, {'render_rest': false}) }}
{% endblock %}

{% block javascripts %}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/fr.js"></script>
<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet"/>
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

<style>
.select2-container .select2-selection--single {
    height: 50px;
    border: 1.5px solid #e5e7eb;
    border-radius: 0.75rem;
    background: #f9fafb;
    padding-left: 2.5rem;
}
.select2-container .select2-selection--single .select2-selection__rendered {
    line-height: 48px;
    padding-left: 0;
    font-size: 16px;
    color: #111827;
}
.select2-container .select2-selection--single .select2-selection__arrow {
    height: 48px;
    right: 10px;
}
.select2-container--default .select2-selection--single:focus,
.select2-container--default.select2-container--open .select2-selection--single {
    border-color: #ec4899;
    box-shadow: 0 0 0 3px rgba(236,72,153,0.1);
}
.flatpickr-calendar { font-family: inherit; }
.flatpickr-day.selected { background: #ec4899; border-color: #ec4899; }
.flatpickr-day.today { border-color: #ec4899; color: #ec4899; }
.flatpickr-day:hover { background: #fdf2f8; }
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Select2
    $('.js-client-select').select2({ placeholder: 'Choisir un client', allowClear: true, width: '100%' });

    const slotsSelect = document.getElementById('admin_add_rdv_creneau');
    const availabilityMsg = document.getElementById('availability-message');

    flatpickr('#datepicker', {
        enableTime: false,
        dateFormat: 'Y-m-d',
        altInput: true,
        altFormat: 'l j F Y',
        locale: 'fr',
        minDate: 'today',
        disable: [d => d.getDay() === 0 || d.getDay() === 1],
        onChange: function(selectedDates, dateStr) {
            if (selectedDates.length > 0) { loadSlots(dateStr); }
            else { resetSlots(); }
        }
    });

    function loadSlots(date) {
        if (slotsSelect) {
            slotsSelect.disabled = true;
            slotsSelect.innerHTML = '<option>Chargement...</option>';
        }
        if (availabilityMsg) {
            availabilityMsg.classList.remove('hidden');
            availabilityMsg.innerHTML = '<p class="text-xs text-yellow-700 bg-yellow-50 rounded-lg p-2 border border-yellow-200">Chargement des créneaux...</p>';
        }
        const xhr = new XMLHttpRequest();
        xhr.open('POST', '/get-available-slots', true);
        xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
        xhr.onreadystatechange = function() {
            if (xhr.readyState === 4 && xhr.status === 200) {
                const slots = JSON.parse(xhr.responseText);
                if (slotsSelect) {
                    slotsSelect.innerHTML = '';
                    const def = document.createElement('option');
                    def.value = '';
                    def.text = slots.length > 0 ? 'Sélectionner un créneau' : 'Aucun créneau disponible';
                    slotsSelect.appendChild(def);
                    slots.forEach(s => {
                        const opt = document.createElement('option');
                        opt.value = s.id; opt.text = s.libelle;
                        slotsSelect.appendChild(opt);
                    });
                    slotsSelect.disabled = slots.length === 0;
                }
                if (availabilityMsg) {
                    availabilityMsg.innerHTML = slots.length > 0
                        ? `<p class="text-xs text-green-700 bg-green-50 rounded-lg p-2 border border-green-200">${slots.length} créneau${slots.length > 1 ? 'x' : ''} disponible${slots.length > 1 ? 's' : ''}</p>`
                        : '<p class="text-xs text-red-700 bg-red-50 rounded-lg p-2 border border-red-200">Aucun créneau disponible</p>';
                }
            }
        };
        xhr.send('date=' + date);
    }

    function resetSlots() {
        if (slotsSelect) {
            slotsSelect.innerHTML = "<option>Sélectionnez d'abord une date</option>";
            slotsSelect.disabled = true;
        }
        if (availabilityMsg) availabilityMsg.classList.add('hidden');
    }

    resetSlots();
});
</script>
{% endblock %}
