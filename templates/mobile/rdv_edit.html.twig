{% extends 'mobile/base.html.twig' %}

{% block title %}Reporter RDV - Mobile{% endblock %}
{% block page_title %}Reporter le RDV{% endblock %}

{% block topbar_left %}
<a href="{{ path('app_mobile_rendezvous') }}" class="w-8 h-8 flex items-center justify-center rounded-full bg-gray-100">
    <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
    </svg>
</a>
{% endblock %}

{% block content %}
<!-- Infos du RDV actuel -->
<div class="card mb-4">
    <h2 class="text-sm font-bold text-gray-500 uppercase tracking-wide mb-3">Rendez-vous actuel</h2>
    <div class="space-y-2.5">
        <div class="flex items-center gap-3">
            <div class="w-8 h-8 bg-pink-100 rounded-full flex items-center justify-center flex-shrink-0">
                <svg class="w-4 h-4 text-pink-600" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"/>
                </svg>
            </div>
            <div>
                <p class="text-xs text-gray-400">Client</p>
                <p class="text-sm font-semibold text-gray-900">{{ rendezvous.user ? rendezvous.user.fullName : 'Inconnu' }}</p>
            </div>
        </div>
        <div class="flex items-center gap-3">
            <div class="w-8 h-8 bg-purple-100 rounded-full flex items-center justify-center flex-shrink-0">
                <svg class="w-4 h-4 text-purple-600" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M6 6V5a3 3 0 013-3h2a3 3 0 013 3v1h2a2 2 0 012 2v6a2 2 0 01-2 2H4a2 2 0 01-2-2V8a2 2 0 012-2h2zm4-3a1 1 0 00-1 1v1h2V4a1 1 0 00-1-1z" clip-rule="evenodd"/>
                </svg>
            </div>
            <div>
                <p class="text-xs text-gray-400">Prestation</p>
                <p class="text-sm font-semibold text-gray-900">{{ rendezvous.prestation.title }}</p>
            </div>
        </div>
        <div class="flex items-center gap-3">
            <div class="w-8 h-8 bg-green-100 rounded-full flex items-center justify-center flex-shrink-0">
                <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"/>
                </svg>
            </div>
            <div>
                <p class="text-xs text-gray-400">Date actuelle</p>
                <p class="text-sm font-semibold text-gray-900">{{ rendezvous.day|date('l d/m/Y') }}</p>
            </div>
        </div>
        <div class="flex items-center gap-3">
            <div class="w-8 h-8 bg-orange-100 rounded-full flex items-center justify-center flex-shrink-0">
                <svg class="w-4 h-4 text-orange-600" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/>
                </svg>
            </div>
            <div>
                <p class="text-xs text-gray-400">Créneau actuel</p>
                <p class="text-sm font-semibold text-gray-900">{{ rendezvous.creneau.startTime|date('H:i') }} – {{ rendezvous.creneau.endTime|date('H:i') }}</p>
            </div>
        </div>
    </div>
</div>

<!-- Formulaire de modification -->
<div class="card bg-blue-50 border border-blue-200 !mb-4">
    <div class="flex items-start gap-2">
        <svg class="w-5 h-5 text-blue-600 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
        </svg>
        <p class="text-sm text-blue-800">Le client sera notifié par email de la modification.</p>
    </div>
</div>

{{ form_start(form, {'attr': {'id': 'edit-form', 'novalidate': 'novalidate'}}) }}

<div class="form-group">
    <label class="form-label" for="datepicker">Nouvelle date *</label>
    <div class="relative">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400 pointer-events-none" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"/>
        </svg>
        <input type="text"
               name="{{ field_name(form.day) }}"
               value="{{ field_value(form.day) }}"
               placeholder="Choisir une nouvelle date"
               class="form-control pl-10"
               id="datepicker"
               readonly>
    </div>
    <p class="text-xs text-gray-400 mt-1">Du mardi au samedi uniquement</p>
</div>

<div class="form-group">
    <label class="form-label">Nouveau créneau *</label>
    <div id="creneaux-container">
        {{ form_widget(form.creneau, {'attr': {'class': 'form-control', 'id': 'rendezvous_modify_creneau', 'disabled': 'disabled'}}) }}
    </div>
    <div id="availability-message" class="hidden mt-2"></div>
</div>

<div class="space-y-3 pt-2">
    <button type="submit" class="btn-primary gap-2">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
        </svg>
        Confirmer le report
    </button>
    <a href="{{ path('app_mobile_rendezvous') }}" class="btn-secondary gap-2">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
        Annuler
    </a>
</div>

{{ form_widget(form._token) }}
{{ form_end(form, {'render_rest': false}) }}
{% endblock %}

{% block javascripts %}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/fr.js"></script>

<style>
.flatpickr-day.selected { background: #ec4899; border-color: #ec4899; }
.flatpickr-day.today { border-color: #ec4899; color: #ec4899; }
.flatpickr-day:hover { background: #fdf2f8; }
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const slotsSelect = document.getElementById('rendezvous_modify_creneau');
    const availabilityMsg = document.getElementById('availability-message');

    flatpickr('#datepicker', {
        enableTime: false,
        dateFormat: 'Y-m-d',
        altInput: true,
        altFormat: 'l j F Y',
        locale: 'fr',
        minDate: 'today',
        disable: [d => d.getDay() === 0 || d.getDay() === 1],
        onChange: function(selectedDates, dateStr) {
            if (selectedDates.length > 0) { loadSlots(dateStr); }
            else { resetSlots(); }
        }
    });

    function loadSlots(date) {
        if (slotsSelect) {
            slotsSelect.disabled = true;
            slotsSelect.innerHTML = '<option>Chargement...</option>';
        }
        if (availabilityMsg) {
            availabilityMsg.classList.remove('hidden');
            availabilityMsg.innerHTML = '<p class="text-xs text-yellow-700 bg-yellow-50 rounded-lg p-2 border border-yellow-200">Chargement des créneaux...</p>';
        }
        const xhr = new XMLHttpRequest();
        xhr.open('POST', '/get-available-slots', true);
        xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
        xhr.onreadystatechange = function() {
            if (xhr.readyState === 4 && xhr.status === 200) {
                const slots = JSON.parse(xhr.responseText);
                if (slotsSelect) {
                    slotsSelect.innerHTML = '<option value="">Sélectionner un créneau</option>';
                    slots.forEach(s => {
                        const opt = document.createElement('option');
                        opt.value = s.id; opt.text = s.libelle;
                        slotsSelect.appendChild(opt);
                    });
                    slotsSelect.disabled = slots.length === 0;
                }
                if (availabilityMsg) {
                    availabilityMsg.innerHTML = slots.length > 0
                        ? `<p class="text-xs text-green-700 bg-green-50 rounded-lg p-2 border border-green-200">${slots.length} créneau${slots.length > 1 ? 'x' : ''} disponible${slots.length > 1 ? 's' : ''}</p>`
                        : '<p class="text-xs text-red-700 bg-red-50 rounded-lg p-2 border border-red-200">Aucun créneau disponible</p>';
                }
            }
        };
        xhr.send('date=' + date);
    }

    function resetSlots() {
        if (slotsSelect) {
            slotsSelect.innerHTML = "<option>Sélectionnez d'abord une date</option>";
            slotsSelect.disabled = true;
        }
        if (availabilityMsg) availabilityMsg.classList.add('hidden');
    }

    resetSlots();
});
</script>
{% endblock %}
